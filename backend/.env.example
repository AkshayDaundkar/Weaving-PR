# Data (paths: data_path, raw_path, processed_path, output_path under DATA_DIR)
# DATA_DIR=data

# GitHub (required for pipeline; optional for API)
# GITHUB_TOKEN=
# GITHUB_ORG=PostHog
# GITHUB_REPO=posthog

# LLM
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# LLM_PROVIDER=openai
# LLM_MODEL_CLASSIFY=gpt-4o-mini
# LLM_MODEL_NARRATIVE=claude-3-5-sonnet-20241022
# LLM_BATCH_SIZE=25

# Server
# HOST=0.0.0.0
# PORT=8000

# Pipeline
# DAYS_LOOKBACK=90
# MIN_PRS_TO_QUALIFY=3
# MIN_REVIEWS_TO_QUALIFY=5
